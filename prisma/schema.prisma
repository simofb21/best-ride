generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  weightKg           Decimal? @db.Decimal(5, 2)
  ftp                Int?
  anaerobicThreshold Int?
  yearlyDistanceKm      Decimal? @db.Decimal(8, 2)
  yearlyHours           Decimal? @db.Decimal(6, 1) 
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  sex               String? @db.VarChar(1)
  dateOfBirth       DateTime? @db.Date
  lastActivity  LastActivity?
  customRecords CustomRecord[]

  recordPeakPower   RecordPeakPower[]
  record3s          Record3s[]
  record5s          Record5s[]
  record10s         Record10s[]
  record20s         Record20s[]
  record30s         Record30s[]
  record1min        Record1min[]
  record2min        Record2min[]
  record3min        Record3min[]
  record5min        Record5min[]
  record8min        Record8min[]
  record10min       Record10min[]
  record12min       Record12min[]
  record15min       Record15min[]
  record20min       Record20min[]
  record30min       Record30min[]
  record60min       Record60min[]

  recordDistance      RecordDistance[]
  recordElevationGain RecordElevationGain[]
  recordDuration      RecordDuration[]
  recordKilojoules    RecordKilojoules[]
  recordMaxCadence    RecordMaxCadence[]
  recordMaxSpeed      RecordMaxSpeed[]
  recordMaxHeartrate  RecordMaxHeartrate[]
  recordHr5min        RecordHr5min[]
  recordHr20min       RecordHr20min[]
  recordHr1h          RecordHr1h[]

  @@map("users")
}

model LastActivity {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique
  filename               String
  uploadedAt             DateTime @default(now())
  ftpUsed                Int
  anaerobicThresholdUsed Int
  data                   Json

  user User @relation(fields: [userId], references: [id])

  @@map("last_activity")
}

model CustomRecord {
  id            Int      @id @default(autoincrement())
  userId        Int
  slug          String
  label         String
  unit          String
  lowerIsBetter Boolean  @default(false)
  createdAt     DateTime @default(now())
  entries       Json?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, slug])
  @@map("custom_records")
}

// ============================================================
// POWER CURVE — 17 tabelle, tutte con la stessa identica struttura
// ============================================================

model RecordPeakPower {
  id          Int      @id @default(autoincrement())
  userId      Int
  rank        Int
  value       Decimal  @db.Decimal(10, 2)
  entryDate   DateTime @db.Date
  description String?  @db.VarChar(500)
  activityId  String?
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, rank])
  @@map("record_peak_power")
}

