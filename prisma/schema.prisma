generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  weightKg           Decimal? @db.Decimal(5, 2)
  ftp                Int?
  anaerobicThreshold Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lastActivity LastActivity?
  records      UserRecords?

  @@map("users")
}

// Una sola riga per utente: l'ultima attività caricata.
// Ad ogni nuovo upload questa riga viene sovrascritta (upsert), non se ne accumulano altre.
model LastActivity {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique
  filename               String
  uploadedAt             DateTime @default(now())
  ftpUsed                Int
  anaerobicThresholdUsed Int

  // Tutto il payload calcolato: riepilogo attività, power curve, training load,
  // e in futuro streams/mappa/salite/zone. Il server lo rilegge da qui,
  // niente colonne separate per ogni singolo dato.
  data Json

  user User @relation(fields: [userId], references: [id])

  @@map("last_activity")
}

// Una sola riga per utente: contiene i "podi" (top 3) di ogni metrica.
// Ogni campo è un array JSON tipo:
// [{ "value": 320, "date": "2024-06-01", "description": "vento forte" }, ...]
model UserRecords {
  id     Int @id @default(autoincrement())
  userId Int @unique

  // --- Power curve (intervalli brevi) ---
  peakPower Json?
  power3s   Json?
  power5s   Json?
  power10s  Json?
  power20s  Json?
  power30s  Json?
  power1min Json?
  power2min Json?
  power3min Json?

  // --- Power curve (intervalli medi) ---
  power5min  Json?
  power8min  Json?
  power10min Json?
  power12min Json?

  // --- Power curve (intervalli lunghi) ---
  power15min Json?
  power20min Json?
  power30min Json?
  power60min Json?

  // --- Riepilogo attività ---
  averageWatts    Json?
  normalizedPower Json?
  averageSpeed    Json?
  maxSpeed        Json?
  distance        Json?
  duration        Json?
  elevationGain   Json?
  tss             Json?

  // Record personalizzati creati dall'utente (es. "Salita allo Stelvio"):
  // { "stelvio_climb": { "label": "...", "unit": "min", "lowerIsBetter": true, "entries": [...] } }
  customRecords Json?

  user User @relation(fields: [userId], references: [id])

  @@map("user_records")
}