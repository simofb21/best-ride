generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============================================================
// USER — l'utente registrato
// ============================================================
model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  weightKg           Decimal? @db.Decimal(5, 2)
  ftp                Int?
  anaerobicThreshold Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lastActivity  LastActivity?
  records       UserRecords?
  customRecords CustomRecord[]

  @@map("users")
}

// ============================================================
// LAST ACTIVITY — una sola riga per utente, sempre sovrascritta
// ============================================================
model LastActivity {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique
  filename               String
  uploadedAt             DateTime @default(now())
  ftpUsed                Int
  anaerobicThresholdUsed Int

  // Tutto il payload calcolato in un unico JSON: riepilogo attività,
  // power curve, training load, e in futuro streams/mappa/salite/zone.
  data Json

  user User @relation(fields: [userId], references: [id])

  @@map("last_activity")
}

// ============================================================
// USER RECORDS — una sola riga per utente: i podi (top-3) dei record DI DEFAULT
// ============================================================
model UserRecords {
  id     Int @id @default(autoincrement())
  userId Int @unique

  // --- Power curve: intervalli brevi ---
  peakPower Json?
  power3s   Json?
  power5s   Json?
  power10s  Json?
  power20s  Json?
  power30s  Json?
  power1min Json?
  power2min Json?
  power3min Json?

  // --- Power curve: intervalli medi ---
  power5min  Json?
  power8min  Json?
  power10min Json?
  power12min Json?

  // --- Power curve: intervalli lunghi ---
  power15min Json?
  power20min Json?
  power30min Json?
  power60min Json?

  // --- Riepilogo attività ---
  averageWatts    Json?
  normalizedPower Json?
  averageSpeed    Json?
  maxSpeed        Json?
  distance        Json?
  duration        Json?
  elevationGain   Json?
  tss             Json?

  user User @relation(fields: [userId], references: [id])

  @@map("user_records")
}

// ============================================================
// CUSTOM RECORD — una riga per ogni record PERSONALIZZATO creato dall'utente
// ============================================================
model CustomRecord {
  id            Int      @id @default(autoincrement())
  userId        Int
  slug          String
  label         String
  unit          String
  lowerIsBetter Boolean  @default(false)
  createdAt     DateTime @default(now())

  // Le sue top-3 performance: [{ value, date, description }, ...]
  entries Json?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, slug])
  @@map("custom_records")
}